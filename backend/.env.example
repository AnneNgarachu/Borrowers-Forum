# ==========================================
# Borrower's Forum Platform - Configuration Template
# ==========================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace placeholder values with your actual credentials
# 3. NEVER commit .env to Git (it's in .gitignore)
#
# ==========================================

# Database Configuration (Supabase PostgreSQL)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres.xxxxx:[YOUR_PASSWORD_HERE]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Example (DO NOT USE - replace with your actual values):
# DATABASE_URL=postgresql://postgres.abcdefgh:SecurePass123!@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ==========================================
# Security Notes:
# ==========================================
# - Get your actual DATABASE_URL from Supabase dashboard
# - Password should be stored in a password manager (1Password, Bitwarden, etc.)
# - Never share this file or commit it to version control
# - For production deployment, use environment variables in Railway/Render
#
# ==========================================